<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="WordMD.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WordMD"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="WordMD"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Grid.Row="0" Title="WordMD">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <MenuBar Grid.Row="1">
            <MenuBarItem Title="File">
                <MenuFlyoutItem Text="New" Click="MenuNew_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="N" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Open..." Click="MenuOpen_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="O" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSubItem x:Name="OpenRecentMenu" Text="Open Recent" />
                <MenuFlyoutItem Text="Reload from Disk" Click="MenuReload_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Key="F5" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <ToggleMenuFlyoutItem x:Name="AutoReloadMenuItem" Text="Auto-reload when changed externally" Click="MenuAutoReload_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Save" Click="MenuSave_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="S" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Save As..." Click="MenuSaveAs_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control,Shift" Key="S" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="New Tab" Click="MenuNewTab_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="T" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Close Tab" Click="MenuCloseTab_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="W" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Exit" Click="MenuExit_Click" />
            </MenuBarItem>
            <MenuBarItem Title="Edit">
                <MenuFlyoutItem Text="Find..." Click="MenuFind_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="F" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Replace..." Click="MenuReplace_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="H" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
            </MenuBarItem>
            <MenuBarItem Title="View">
                <MenuFlyoutItem Text="Source"    Click="ModeSource_Click" />
                <MenuFlyoutItem Text="Formatted" Click="ModeFormatted_Click" />
                <MenuFlyoutItem Text="Split"     Click="ModeSplit_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Toggle Mode (Ctrl+/)" Click="MenuToggleMode_Click" />
                <MenuFlyoutSeparator />
                <RadioMenuFlyoutItem x:Name="ThemeLightMenu"  Text="Light Theme"  GroupName="theme" Click="MenuThemeLight_Click" IsChecked="True" />
                <RadioMenuFlyoutItem x:Name="ThemeDarkMenu"   Text="Dark Theme"   GroupName="theme" Click="MenuThemeDark_Click" />
                <RadioMenuFlyoutItem x:Name="ThemeSystemMenu" Text="System Theme" GroupName="theme" Click="MenuThemeSystem_Click" />
                <MenuFlyoutSeparator />
                <ToggleMenuFlyoutItem x:Name="ScrollSyncMenu"   Text="Sync Scrolling (Split Mode)" Click="MenuScrollSyncToggle_Click"   IsChecked="True" />
                <ToggleMenuFlyoutItem x:Name="LockToSourceMenu" Text="Lock to Source"              Click="MenuLockToSourceToggle_Click" IsChecked="True" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Zoom In"    Click="MenuZoomIn_Click" />
                <MenuFlyoutItem Text="Zoom Out"   Click="MenuZoomOut_Click" />
                <MenuFlyoutItem Text="Reset Zoom" Click="MenuZoomReset_Click" />
            </MenuBarItem>
            <MenuBarItem Title="Insert">
                <MenuFlyoutItem Text="Link..."         Click="CmdLink_Click" />
                <MenuFlyoutItem Text="Image..."        Click="CmdImage_Click" />
                <MenuFlyoutItem Text="Code Block"      Click="CmdCodeBlock_Click" />
                <MenuFlyoutItem Text="Table..."        Click="CmdTable_Click" />
                <MenuFlyoutItem Text="Horizontal Rule" Click="CmdHr_Click" />
            </MenuBarItem>
            <MenuBarItem Title="Format">
                <MenuFlyoutItem Text="Bold"          Click="CmdBold_Click" />
                <MenuFlyoutItem Text="Italic"        Click="CmdItalic_Click" />
                <MenuFlyoutItem Text="Strikethrough" Click="CmdStrike_Click" />
                <MenuFlyoutItem Text="Inline Code"   Click="CmdInlineCode_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Heading 1" Click="CmdH1_Click" />
                <MenuFlyoutItem Text="Heading 2" Click="CmdH2_Click" />
                <MenuFlyoutItem Text="Heading 3" Click="CmdH3_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Bullet List"   Click="CmdBullet_Click" />
                <MenuFlyoutItem Text="Numbered List" Click="CmdNumbered_Click" />
                <MenuFlyoutItem Text="Task List"     Click="CmdTask_Click" />
                <MenuFlyoutItem Text="Blockquote"    Click="CmdQuote_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Clear Formatting" Click="CmdClear_Click" />
            </MenuBarItem>
            <MenuBarItem Title="Help">
                <MenuFlyoutItem Text="User Guide" Click="MenuUserGuide_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Key="F1" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Send Feedback..." Click="MenuFeedback_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control,Shift" Key="F1" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="Open Feedback Log Folder" Click="MenuOpenFeedbackFolder_Click" />
                <MenuFlyoutSeparator />
                <ToggleMenuFlyoutItem x:Name="TelemetryMenuItem" Text="Send Anonymous Usage Data" Click="MenuTelemetryToggle_Click" />
                <MenuFlyoutItem Text="Open Telemetry Log Folder" Click="MenuOpenTelemetryFolder_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="View on GitHub" Click="MenuGitHub_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="About WordMD" Click="MenuAbout_Click" />
            </MenuBarItem>
        </MenuBar>

        <Grid Grid.Row="2" Padding="8,4">
            <Grid.Resources>
                <Style x:Key="ToolbarIconButton" TargetType="Button">
                    <Setter Property="Width" Value="36" />
                    <Setter Property="Height" Value="32" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                </Style>
                <Style x:Key="ToolbarDropDownButton" TargetType="DropDownButton">
                    <Setter Property="MinWidth" Value="52" />
                    <Setter Property="Height" Value="32" />
                    <Setter Property="Padding" Value="8,0" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                </Style>
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="2" Grid.Column="0">
                <Button Style="{StaticResource ToolbarIconButton}" ToolTipService.ToolTip="Bold (Ctrl+B)" Click="CmdBold_Click">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8DD;" FontSize="16" />
                </Button>
                <Button Style="{StaticResource ToolbarIconButton}" ToolTipService.ToolTip="Italic (Ctrl+I)" Click="CmdItalic_Click">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8DB;" FontSize="16" />
                </Button>
                <Button Style="{StaticResource ToolbarIconButton}" ToolTipService.ToolTip="Strikethrough (Ctrl+Shift+X)" Click="CmdStrike_Click">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEDE0;" FontSize="16" />
                </Button>
                <Button Style="{StaticResource ToolbarIconButton}" ToolTipService.ToolTip="Inline Code (Ctrl+`)" Click="CmdInlineCode_Click">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE943;" FontSize="16" />
                </Button>
                <AppBarSeparator />
                <Button x:Name="ReloadBtn" Style="{StaticResource ToolbarIconButton}" ToolTipService.ToolTip="Reload from Disk (F5)" Click="MenuReload_Click">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE72C;" FontSize="16" />
                </Button>
                <AppBarSeparator />
                <DropDownButton Style="{StaticResource ToolbarDropDownButton}" ToolTipService.ToolTip="Heading">
                    <DropDownButton.Content>
                        <TextBlock Text="H" FontWeight="SemiBold" FontSize="15" />
                    </DropDownButton.Content>
                    <DropDownButton.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Heading 1" Click="CmdH1_Click" />
                            <MenuFlyoutItem Text="Heading 2" Click="CmdH2_Click" />
                            <MenuFlyoutItem Text="Heading 3" Click="CmdH3_Click" />
                            <MenuFlyoutItem Text="Heading 4" Click="CmdH4_Click" />
                            <MenuFlyoutItem Text="Heading 5" Click="CmdH5_Click" />
                            <MenuFlyoutItem Text="Heading 6" Click="CmdH6_Click" />
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
                <AppBarSeparator />
                <Button Style="{StaticResource ToolbarIconButton}" ToolTipService.ToolTip="Bullet List (Ctrl+Shift+L)" Click="CmdBullet_Click">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8FD;" FontSize="16" />
                </Button>
                <Button Style="{StaticResource ToolbarIconButton}" ToolTipService.ToolTip="Numbered List (Ctrl+Shift+O)" Click="CmdNumbered_Click">
                    <Viewbox Width="16" Height="16">
                        <PathIcon Data="M2 17h2v.5H3v1h1v.5H2v1h3v-4H2v1zm1-9h1V4H2v1h1v3zm-1 3h1.8L2 13.1v.9h3v-1H3.2L5 10.9V10H2v1zm5-6v2h14V5H7zm0 14h14v-2H7v2zm0-6h14v-2H7v2z" />
                    </Viewbox>
                </Button>
                <Button Style="{StaticResource ToolbarIconButton}" ToolTipService.ToolTip="Task List (Ctrl+Shift+T)" Click="CmdTask_Click">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE9D5;" FontSize="16" />
                </Button>
                <Button Style="{StaticResource ToolbarIconButton}" ToolTipService.ToolTip="Blockquote (Ctrl+Shift+Q)" Click="CmdQuote_Click">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE848;" FontSize="16" />
                </Button>
                <AppBarSeparator />
                <Button Style="{StaticResource ToolbarIconButton}" ToolTipService.ToolTip="Link (Ctrl+K)" Click="CmdLink_Click">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE71B;" FontSize="16" />
                </Button>
                <Button Style="{StaticResource ToolbarIconButton}" ToolTipService.ToolTip="Image (Ctrl+Shift+I)" Click="CmdImage_Click">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEB9F;" FontSize="16" />
                </Button>
                <Button Style="{StaticResource ToolbarIconButton}" ToolTipService.ToolTip="Code Block (Ctrl+Shift+K)" Click="CmdCodeBlock_Click">
                    <Viewbox Width="16" Height="16">
                        <PathIcon Data="M4 7v2c0 .55-.45 1-1 1H2v2h1c.55 0 1 .45 1 1v2c0 1.65 1.35 3 3 3h3v-2H7c-.55 0-1-.45-1-1v-2c0-1.3-.84-2.42-2-2.83v-.34C5.16 9.42 6 8.3 6 7V5c0-.55.45-1 1-1h3V2H7C5.35 2 4 3.35 4 5v2zm17 3c-.55 0-1-.45-1-1V7c0-1.65-1.35-3-3-3h-3v2h3c.55 0 1 .45 1 1v2c0 1.3.84 2.42 2 2.83v.34c-1.16.41-2 1.53-2 2.83v2c0 .55-.45 1-1 1h-3v2h3c1.65 0 3-1.35 3-3v-2c0-.55.45-1 1-1h1v-2h-1z" />
                    </Viewbox>
                </Button>
                <Button Style="{StaticResource ToolbarIconButton}" ToolTipService.ToolTip="Table (Ctrl+Shift+B)" Click="CmdTable_Click">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xF0E2;" FontSize="16" />
                </Button>
                <Button Style="{StaticResource ToolbarIconButton}" ToolTipService.ToolTip="Horizontal Rule (Ctrl+Shift+H)" Click="CmdHr_Click">
                    <Viewbox Width="16" Height="16">
                        <PathIcon Data="M4 11h16v2H4z" />
                    </Viewbox>
                </Button>
                <AppBarSeparator />
                <Button Style="{StaticResource ToolbarIconButton}" ToolTipService.ToolTip="Clear Formatting (Ctrl+Space)" Click="CmdClear_Click">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xED62;" FontSize="16" />
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Grid.Column="1" Spacing="0">
                <ToggleButton x:Name="ModeSourceBtn"    Content="Source"    Click="ModeSource_Click"    CornerRadius="4,0,0,4" />
                <ToggleButton x:Name="ModeFormattedBtn" Content="Formatted" Click="ModeFormatted_Click" CornerRadius="0" IsChecked="True" />
                <ToggleButton x:Name="ModeSplitBtn"     Content="Split"     Click="ModeSplit_Click"     CornerRadius="0,4,4,0" />
            </StackPanel>
        </Grid>

        <TabView x:Name="DocTabs"
                 Grid.Row="3"
                 IsAddTabButtonVisible="True"
                 TabWidthMode="Equal"
                 CanReorderTabs="True"
                 CanDragTabs="False"
                 AddTabButtonClick="Tabs_AddTabButtonClick"
                 TabCloseRequested="Tabs_TabCloseRequested"
                 SelectionChanged="Tabs_SelectionChanged" />

        <Border Grid.Row="4" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,1">
            <controls:WebView2 x:Name="EditorView" />
        </Border>

        <Grid Grid.Row="5" Padding="10,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusFile" Grid.Column="0" Text="Untitled.md" />
            <TextBlock x:Name="StatusWords" Grid.Column="1" Margin="12,0" Text="Words: 0" />
            <TextBlock x:Name="StatusChars" Grid.Column="2" Margin="12,0" Text="Chars: 0" />
            <TextBlock x:Name="StatusRead"  Grid.Column="3" Margin="12,0" Text="Read: 0 min" />
            <TextBlock x:Name="StatusEol"   Grid.Column="4" Margin="12,0" Text="CRLF" />
            <TextBlock x:Name="StatusEnc"   Grid.Column="5" Margin="12,0" Text="UTF-8" />
            <TextBlock x:Name="StatusVersion" Grid.Column="6" Margin="12,0,0,0" Opacity="0.65" Text="v1.4.5" />
        </Grid>
    </Grid>
</Window>
